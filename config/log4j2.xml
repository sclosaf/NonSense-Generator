<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
	<Properties>
		<Property name="log.dir">logs</Property>
		<Property name="log.file">${log.dir}/app.log</Property>
	</Properties>

	<Appenders>
		<RollingFile name="FileLogger" fileName="${log.file}" filePattern="${log.dir}/app_%i.log">
			<PatternLayout pattern="%d %-5level - %msg%n" />
			<Policies>
				<OnStartupTriggeringPolicy />
				<SizeBasedTriggeringPolicy size="10MB" />
			</Policies>
			<DefaultRolloverStrategy max="5" fileIndex="min"/>
		</RollingFile>
		<Console name="ConsoleLogger" target="SYSTEM_OUT">
			<PatternLayout pattern="%highlight{%-5level} - %msg%n"
				disableAnsi="false" noConsoleNoAnsi="false" />
		</Console>
		<Async name="AsyncFileLogger">
			<AppenderRef ref="FileLogger"/>
		</Async>
		<Async name="AsyncConsoleLogger">
			<AppenderRef ref="ConsoleLogger"/>
		</Async>
	</Appenders>

	<Loggers>
		<Logger name="FileLogger" level="trace" additivity="false">
			<AppenderRef ref="AsyncFileLogger" />
		</Logger>
		<Logger name="ConsoleLogger" level="info" additivity="false">
			<AppenderRef ref="AsyncConsoleLogger" />
		</Logger>
		<Root level="error">
			<AppenderRef ref="AsyncFileLogger" />
			<AppenderRef ref="AsyncConsoleLogger" />
		</Root>
	</Loggers>
</Configuration>
