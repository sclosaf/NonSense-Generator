<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
	<Properties>
		<Property name="log.dir">logs</Property>
		<Property name="timestamp">${date:yyyy-MM-dd_HH-mm-ss}</Property>
		<Property name="log.file">${log.dir}/app_${timestamp}.log</Property>
	</Properties>

	<Appenders>
		<RollingFile name="FileLogger" fileName="${log.file}" filePattern="${log.dir}/app_%d{yyyy-MM-dd_HH-mm-ss}.log">
			<PatternLayout pattern="%d [%t] %-5level %logger{36} - %msg%n" />
			<Policies>
				<OnStartupTriggeringPolicy />
			</Policies>
			<DefaultRolloverStrategy max="6" />
		</RollingFile>
		<Console name="ConsoleLogger" target="SYSTEM_OUT">
			<PatternLayout pattern="[%style{%t}{blue}] %highlight{%-5level} %logger{36} - %msg%n"
				disableAnsi="false" noConsoleNoAnsi="false" />
		</Console>
	</Appenders>

	<Loggers>
		<Logger name="FileLogger" level="trace" additivity="false">
			<AppenderRef ref="FileLogger" />
		</Logger>
		<Logger name="ConsoleLogger" level="info" additivity="false">
			<AppenderRef ref="ConsoleLogger" />
		</Logger>
		<Root level="trace">
		</Root>
	</Loggers>
</Configuration>
